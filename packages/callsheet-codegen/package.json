{
  "name": "@callsheet/codegen",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "callsheet-codegen": "./bin/callsheet-codegen.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsd --typings dist/index.d.ts --files test-d/**/*.test-d.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@ts-rest/core": "^3.52.1",
    "@callsheet/react-query": "workspace:*",
    "@callsheet/ts-rest": "workspace:*",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@callsheet/react-query": "^0.0.1",
    "@callsheet/ts-rest": "^0.0.1",
    "@ts-rest/core": "^3.52.1",
    "typescript": ">=5"
  },
  "peerDependenciesMeta": {
    "@callsheet/ts-rest": {
      "optional": true
    },
    "@ts-rest/core": {
      "optional": true
    }
  }
}
