{
  "name": "callsheet-codegen",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsd --typings dist/index.d.ts --files test-d/**/*.test-d.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "callsheet": "workspace:*",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "callsheet": "^0.0.1",
    "typescript": ">=5"
  }
}
