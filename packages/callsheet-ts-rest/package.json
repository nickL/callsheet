{
  "name": "@callsheet/ts-rest",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@callsheet/core": "workspace:*"
  },
  "peerDependencies": {
    "@ts-rest/core": "^3.52.1"
  },
  "peerDependenciesMeta": {
    "@ts-rest/core": {
      "optional": true
    }
  }
}
