{
  "name": "@callsheet/react-query",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsd --typings dist/index.d.ts --files test-d/**/*.test-d.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@callsheet/core": "workspace:*"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@ts-rest/core": "^3.52.1",
    "react": "^18 || ^19"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@ts-rest/core": "^3.52.1",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@ts-rest/core": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
