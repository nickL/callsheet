{
  "name": "@callsheet/core",
  "version": "0.2.0",
  "description": "Core types and primitives for Callsheet.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nickL/callsheet.git",
    "directory": "packages/callsheet"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "callsheet",
    "typed-operations",
    "api-client",
    "cache-invalidation",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./swr": {
      "types": "./dist/swr/index.d.ts",
      "import": "./dist/swr/index.js",
      "require": "./dist/swr/index.cjs"
    },
    "./react-query": {
      "types": "./dist/react-query/index.d.ts",
      "import": "./dist/react-query/index.js",
      "require": "./dist/react-query/index.cjs"
    },
    "./ts-rest": {
      "types": "./dist/ts-rest/index.d.ts",
      "import": "./dist/ts-rest/index.js",
      "require": "./dist/ts-rest/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsd --typings dist/index.d.ts --files test-d/**/*.test-d.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/react": "^16.3.2",
    "@ts-rest/core": "^3.52.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "swr": "^2.4.1"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@ts-rest/core": "^3.52.1",
    "react": "^18 || ^19",
    "swr": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "@ts-rest/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "swr": {
      "optional": true
    }
  }
}
