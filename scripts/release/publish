#!/usr/bin/env bash
set -euo pipefail

if [[ "$#" -ne 0 ]]; then
  echo "scripts/release/publish does not accept arguments." >&2
  exit 1
fi

repo_root="$(cd "$(dirname "$0")/../.." && pwd)"
cd "$repo_root"

package_version() {
  node -e "const fs = require('node:fs'); const pkg = JSON.parse(fs.readFileSync(process.argv[1], 'utf8')); console.log(pkg.version);" "$1"
}

publish_package() {
  local package_dir="$1"
  local package_name="$2"
  local version

  version="$(package_version "$package_dir/package.json")"

  if npm view "$package_name@$version" version >/dev/null 2>&1; then
    echo "Skipping $package_name@$version; already published."
    return
  fi

  echo "Publishing $package_name@$version..."
  pnpm --filter "$package_name" publish --no-git-checks --provenance
}

publish_package "packages/callsheet" "@callsheet/core"
publish_package "packages/callsheet-react-query" "@callsheet/react-query"
publish_package "packages/callsheet-swr" "@callsheet/swr"
publish_package "packages/callsheet-ts-rest" "@callsheet/ts-rest"
publish_package "packages/callsheet-codegen" "@callsheet/codegen"
